From 20ec009864514af9138e43a8d380c0ba657c74c8 Mon Sep 17 00:00:00 2001
From: Anton Burticica <mouse@ya.ru>
Date: Mon, 8 Dec 2025 08:35:37 +0200
Subject: [PATCH 2/2] Fix rockchip_rk3588_pll_frac_by_auto

---
 drivers/clk/rockchip/clk-pll.c   | 126 +++++++++++++++----------------
 drivers/gpu/drm/rockchip/dw-dp.c |   5 +-
 2 files changed, 63 insertions(+), 68 deletions(-)

diff --git a/drivers/clk/rockchip/clk-pll.c b/drivers/clk/rockchip/clk-pll.c
index f6d9d199acd8..0cbf410a016b 100644
--- a/drivers/clk/rockchip/clk-pll.c
+++ b/drivers/clk/rockchip/clk-pll.c
@@ -339,66 +339,59 @@ rockchip_rk3066_pll_clk_set_by_auto(struct rockchip_clk_pll *pll,
 	return rate_table;
 }
 
-static u32
-rockchip_rk3588_pll_frac_get(u32 m, u32 p, u32 s, u64 fin_hz, u64 fvco)
-{
-	u64 fref, fout, ffrac, k = 0;
-
-	fref = fin_hz;
-	do_div(fref, p);
-	ffrac = fvco - (m * fref);
-	fout = ffrac * 65536;
-	k = fout;
-	do_div(k, fref);
-	if (k > 32767) {
-		fref = fin_hz;
-		do_div(fref, p);
-		ffrac = ((m + 1) * fref) - fvco;
-		fout = ffrac * 655360;
-		do_div(fout, fref);
-		k = fout + 7;
-		do_div(k, 10);
-		if (k > 32767)
-			k = 0;
-		else
-			k = ~k + 1;
-	}
-	return k;
-}
-
-static struct rockchip_pll_rate_table *
-rockchip_rk3588_pll_frac_by_auto(unsigned long fin_hz,  unsigned long fout_hz)
-{
-	struct rockchip_pll_rate_table *rate_table = rk_pll_rate_table_get();
-	u64 fvco_min = RK3588_PLL_FVCO_MIN, fvco_max = RK3588_PLL_FVCO_MAX;
-	u32 p, m, s, k;
-	u64 fvco;
-
-	for (s = 0; s <= 6; s++) {
-		fvco = (u64)fout_hz << s;
-		if (fvco < fvco_min || fvco > fvco_max)
-			continue;
-		for (p = 1; p <= 4; p++) {
-			for (m = 64; m <= 1023; m++) {
-				if ((fvco >= m * fin_hz / p) && (fvco < (m + 1) * fin_hz / p)) {
-					k = rockchip_rk3588_pll_frac_get(m, p, s,
-									 (u64)fin_hz,
-									 fvco);
-					if (!k)
-						continue;
-					rate_table->p = p;
-					rate_table->s = s;
-					rate_table->k = k;
-					if (k > 32767)
-						rate_table->m = m + 1;
-					else
-						rate_table->m = m;
-					return rate_table;
-				}
-			}
-		}
-	}
-	return NULL;
+static struct rockchip_pll_rate_table *rockchip_rk3588_pll_frac_by_auto(
+            unsigned long fin_hz, unsigned long fout_hz)
+{
+    struct rockchip_pll_rate_table *rate_table = rk_pll_rate_table_get();
+    u64 fvco_min = 2250ULL * MHZ;
+    u64 fvco_max = 4500ULL * MHZ;
+    u64 fvco, fref, ffrac;
+    u32 p, m, s, k;
+
+    for (s = 0; s <= 6; s++) {
+        fvco = (u64)fout_hz << s;
+        if (fvco < fvco_min || fvco > fvco_max)
+            continue;
+
+        /* P must be >= 2 for stability, Fref should be 10-40 MHz */
+        for (p = 2; p <= 63; p++) {
+            fref = fin_hz / p;
+            
+            /* Fref constraint: typically 10-40 MHz */
+            if (fref < 5 * MHZ || fref > 40 * MHZ)
+                continue;
+
+            /* Calculate M (integer part) */
+            m = fvco * p / fin_hz;
+            if (m < 64 || m > 1023)
+                continue;
+
+            /* Calculate K (fractional part): K = (fvco*p/fin - m) * 65536 */
+            ffrac = (u64)fvco * p - (u64)m * fin_hz;
+            k = (ffrac * 65536 + fin_hz / 2) / fin_hz;
+            
+            if (k > 65535)
+                continue;
+
+            /* Verify the result */
+            u64 actual_vco = (u64)fin_hz * m / p + (u64)fin_hz * k / p / 65536;
+            u64 actual_fout = actual_vco >> s;
+            
+            /* Allow small tolerance (100 kHz) */
+            if (abs((long)actual_fout - (long)fout_hz) < 100000) {
+                rate_table->rate = fout_hz;
+                rate_table->p = p;
+                rate_table->m = m;
+                rate_table->s = s;
+                rate_table->k = k;
+                pr_info("%s: found p=%d, m=%d, s=%d, k=%d for fout=%lu (actual=%llu)\n",
+                         __func__, p, m, s, k, fout_hz, actual_fout);
+                return rate_table;
+            }
+        }
+    }
+
+    return NULL;
 }
 
 static struct rockchip_pll_rate_table *
@@ -435,14 +428,13 @@ rockchip_rk3588_pll_clk_set_by_auto(struct rockchip_clk_pll *pll,
 				}
 			}
 		}
-		pr_err("CANNOT FIND Fout by auto,fout = %lu\n", fout_hz);
-	} else {
-		rate_table = rockchip_rk3588_pll_frac_by_auto(fin_hz, fout_hz);
-		if (!rate_table)
-			pr_err("CANNOT FIND Fout by auto,fout = %lu\n", fout_hz);
-		else
-			return rate_table;
 	}
+
+	rate_table = rockchip_rk3588_pll_frac_by_auto(fin_hz, fout_hz);
+	if (rate_table)
+		return rate_table;
+
+	pr_err("CANNOT FIND Fout by auto,fout = %lu\n", fout_hz);
 	return NULL;
 }
 
diff --git a/drivers/gpu/drm/rockchip/dw-dp.c b/drivers/gpu/drm/rockchip/dw-dp.c
index faf1659a569e..728036ad2205 100644
--- a/drivers/gpu/drm/rockchip/dw-dp.c
+++ b/drivers/gpu/drm/rockchip/dw-dp.c
@@ -3597,8 +3597,11 @@ dw_dp_bridge_mode_valid(struct drm_bridge *bridge,
 	    drm_mode_is_420_only(info, &m))
 		return MODE_NO_420;
 
-	if (!dw_dp_bandwidth_ok(dp, &m, min_bpp, link->lanes, link->max_rate))
+	if (!dw_dp_bandwidth_ok(dp, &m, min_bpp, link->lanes, link->max_rate)) {
+		dev_dbg(dp->dev, "mode_valid: %dx%d@%d REJECTED - bandwidth (min_bpp=%d)\n",
+			mode->hdisplay, mode->vdisplay, drm_mode_vrefresh(mode), min_bpp);
 		return MODE_CLOCK_HIGH;
+	}
 
 	if (m.flags & DRM_MODE_FLAG_DBLCLK)
 		return MODE_H_ILLEGAL;
-- 
2.51.0

