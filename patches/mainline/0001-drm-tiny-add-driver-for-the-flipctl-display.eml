FlipCTL is an embedded control board with an SPI-attached grayscale
display. Add a driver for it.

Signed-off-by: Alexey Charkov <alchark@gmail.com>
---
 MAINTAINERS                            |   4 +
 drivers/gpu/drm/tiny/Kconfig           |  14 ++
 drivers/gpu/drm/tiny/Makefile          |   1 +
 drivers/gpu/drm/tiny/flipctl-display.c | 367 +++++++++++++++++++++++++++++++++
 4 files changed, 386 insertions(+)

diff --git a/MAINTAINERS b/MAINTAINERS
index 0dbf349fc1ed..70e5001247db 100644
--- a/MAINTAINERS
+++ b/MAINTAINERS
@@ -7851,6 +7851,10 @@ F:	include/linux/aperture.h
 F:	include/linux/sysfb.h
 F:	include/video/nomodeset.h
 
+DRM DRIVER FOR FLIPPER FLIPCTL DISPLAY
+M:	Alexey Charkov <alchark@gmail.com>
+F:	drivers/gpu/drm/tiny/flipctl-display.c
+
 DRM DRIVER FOR GENERIC EDP PANELS
 R:	Douglas Anderson <dianders@chromium.org>
 F:	Documentation/devicetree/bindings/display/panel/panel-edp.yaml
diff --git a/drivers/gpu/drm/tiny/Kconfig b/drivers/gpu/drm/tiny/Kconfig
index f0e72d4b6a47..03405a474967 100644
--- a/drivers/gpu/drm/tiny/Kconfig
+++ b/drivers/gpu/drm/tiny/Kconfig
@@ -98,6 +98,20 @@ config DRM_PIXPAPER
 
 	  If M is selected, the module will be built as pixpaper.ko.
 
+config TINYDRM_FLIPCTL_DISPLAY
+	tristate "DRM support for Flipper FlipCTL display"
+	depends on DRM && SPI
+	select DRM_CLIENT_SELECTION
+	select DRM_GEM_DMA_HELPER
+	select DRM_KMS_HELPER
+	default y
+	help
+	  DRM Driver for the Flipper embedded control board display, which
+	  uses an onboard MCU to drive a 258x144 grayscale LCD based on a
+	  framebuffer written over SPI (full frame at a time, 8 bpp)
+
+	  If M is selected the module will be called flipctl_display.
+
 config TINYDRM_HX8357D
 	tristate "DRM support for HX8357D display panels"
 	depends on DRM && SPI
diff --git a/drivers/gpu/drm/tiny/Makefile b/drivers/gpu/drm/tiny/Makefile
index 48d30bf6152f..fe746d7e1720 100644
--- a/drivers/gpu/drm/tiny/Makefile
+++ b/drivers/gpu/drm/tiny/Makefile
@@ -7,6 +7,7 @@ obj-$(CONFIG_DRM_CIRRUS_QEMU)		+= cirrus-qemu.o
 obj-$(CONFIG_DRM_GM12U320)		+= gm12u320.o
 obj-$(CONFIG_DRM_PANEL_MIPI_DBI)	+= panel-mipi-dbi.o
 obj-$(CONFIG_DRM_PIXPAPER)              += pixpaper.o
+obj-$(CONFIG_TINYDRM_FLIPCTL_DISPLAY)	+= flipctl-display.o
 obj-$(CONFIG_TINYDRM_HX8357D)		+= hx8357d.o
 obj-$(CONFIG_TINYDRM_ILI9163)		+= ili9163.o
 obj-$(CONFIG_TINYDRM_ILI9225)		+= ili9225.o
diff --git a/drivers/gpu/drm/tiny/flipctl-display.c b/drivers/gpu/drm/tiny/flipctl-display.c
new file mode 100644
index 000000000000..06501aa1069c
--- /dev/null
+++ b/drivers/gpu/drm/tiny/flipctl-display.c
@@ -0,0 +1,367 @@
+// SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+
+#include <drm/clients/drm_client_setup.h>
+#include <drm/drm_atomic.h>
+#include <drm/drm_atomic_helper.h>
+#include <drm/drm_connector.h>
+#include <drm/drm_damage_helper.h>
+#include <drm/drm_drv.h>
+#include <drm/drm_fb_dma_helper.h>
+#include <drm/drm_fbdev_dma.h>
+#include <drm/drm_format_helper.h>
+#include <drm/drm_framebuffer.h>
+#include <drm/drm_gem_atomic_helper.h>
+#include <drm/drm_gem_dma_helper.h>
+#include <drm/drm_gem_framebuffer_helper.h>
+#include <drm/drm_managed.h>
+#include <drm/drm_modes.h>
+#include <drm/drm_probe_helper.h>
+#include <drm/drm_rect.h>
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/mod_devicetable.h>
+#include <linux/module.h>
+#include <linux/spi/spi.h>
+
+struct flipctl_device {
+	struct drm_device drm;
+	struct spi_device *spi;
+
+	const struct drm_display_mode *mode;
+
+	struct drm_crtc crtc;
+	struct drm_plane plane;
+	struct drm_encoder encoder;
+	struct drm_connector connector;
+
+	struct gpio_desc *active_gpio;
+
+	u32 tx_buffer_size;
+	u8 *tx_buffer;
+};
+
+static inline struct flipctl_device *drm_to_flipctl_device(struct drm_device *drm)
+{
+	return container_of(drm, struct flipctl_device, drm);
+}
+
+DEFINE_DRM_GEM_DMA_FOPS(flipctl_fops);
+
+static const struct drm_driver flipctl_drm_driver = {
+	.driver_features	= DRIVER_GEM | DRIVER_MODESET | DRIVER_ATOMIC,
+	.fops			= &flipctl_fops,
+	DRM_GEM_DMA_DRIVER_OPS_VMAP,
+	DRM_FBDEV_DMA_DRIVER_OPS,
+	.name			= "flipctl_display",
+	.desc			= "Flipper FlipCTL LCD screen",
+	.major			= 1,
+	.minor			= 0,
+};
+
+static void flipctl_set_tx_buffer_data(struct flipctl_device *fctl,
+				       struct drm_plane_state *plane_state)
+{
+	struct drm_shadow_plane_state *s_plane_state = to_drm_shadow_plane_state(plane_state);
+	struct drm_framebuffer *fb = plane_state->fb;
+	struct drm_rect clip = {0, fb->width, 0, fb->height};
+	struct iosys_map *src = s_plane_state->data;
+	struct iosys_map dst;
+
+	if (drm_gem_fb_begin_cpu_access(fb, DMA_FROM_DEVICE))
+		return;
+
+	iosys_map_set_vaddr(&dst, fctl->tx_buffer);
+	drm_fb_xrgb8888_to_gray8(&dst, NULL, src, fb, &clip, &s_plane_state->fmtcnv_state);
+	drm_gem_fb_end_cpu_access(fb, DMA_FROM_DEVICE);
+}
+
+static int flipctl_plane_atomic_check(struct drm_plane *plane, struct drm_atomic_state *state)
+{
+	struct drm_plane_state *plane_state = drm_atomic_get_new_plane_state(state, plane);
+	struct flipctl_device *fctl;
+	struct drm_crtc_state *crtc_state;
+
+	fctl = container_of(plane, struct flipctl_device, plane);
+	crtc_state = drm_atomic_get_new_crtc_state(state, &fctl->crtc);
+
+	return drm_atomic_helper_check_plane_state(plane_state, crtc_state,
+						   DRM_PLANE_NO_SCALING,
+						   DRM_PLANE_NO_SCALING,
+						   false, false);
+}
+
+static void flipctl_plane_atomic_update(struct drm_plane *plane, struct drm_atomic_state *state)
+{
+	struct flipctl_device *fctl = container_of(plane, struct flipctl_device, plane);
+	struct drm_plane_state *plane_state = plane->state;
+
+	if (!fctl->crtc.state->active)
+		return;
+
+	/* Populate the transmit buffer with frame data */
+	flipctl_set_tx_buffer_data(fctl, plane_state);
+
+	spi_write(fctl->spi, fctl->tx_buffer, fctl->tx_buffer_size);
+}
+
+static const struct drm_plane_helper_funcs flipctl_plane_helper_funcs = {
+	.prepare_fb = drm_gem_plane_helper_prepare_fb,
+	.atomic_check = flipctl_plane_atomic_check,
+	.atomic_update = flipctl_plane_atomic_update,
+	DRM_GEM_SHADOW_PLANE_HELPER_FUNCS,
+};
+
+static bool flipctl_format_mod_supported(struct drm_plane *plane,
+					      u32 format,
+					      u64 modifier)
+{
+	return modifier == DRM_FORMAT_MOD_LINEAR;
+}
+
+static const struct drm_plane_funcs flipctl_plane_funcs = {
+	.update_plane = drm_atomic_helper_update_plane,
+	.disable_plane = drm_atomic_helper_disable_plane,
+	.destroy = drm_plane_cleanup,
+	DRM_GEM_SHADOW_PLANE_FUNCS,
+	.format_mod_supported = flipctl_format_mod_supported,
+};
+
+static enum drm_mode_status flipctl_crtc_mode_valid(struct drm_crtc *crtc,
+							 const struct drm_display_mode *mode)
+{
+	struct flipctl_device *fctl = drm_to_flipctl_device(crtc->dev);
+
+	return drm_crtc_helper_mode_valid_fixed(crtc, mode, fctl->mode);
+}
+
+static int flipctl_crtc_check(struct drm_crtc *crtc, struct drm_atomic_state *state)
+{
+	struct drm_crtc_state *crtc_state = drm_atomic_get_new_crtc_state(state, crtc);
+	int ret;
+
+	if (!crtc_state->enable)
+		goto out;
+
+	ret = drm_atomic_helper_check_crtc_primary_plane(crtc_state);
+	if (ret)
+		return ret;
+
+out:
+	return drm_atomic_add_affected_planes(state, crtc);
+}
+
+static void flipctl_begin_frame(struct drm_crtc *crtc, struct drm_atomic_state *state)
+{
+	struct flipctl_device *fctl = drm_to_flipctl_device(crtc->dev);
+
+	if (fctl->active_gpio)
+		gpiod_set_value(fctl->active_gpio, 1);
+}
+
+static void flipctl_end_frame(struct drm_crtc *crtc, struct drm_atomic_state *state)
+{
+	struct flipctl_device *fctl = drm_to_flipctl_device(crtc->dev);
+
+	if (fctl->active_gpio)
+		gpiod_set_value(fctl->active_gpio, 0);
+}
+
+static const struct drm_crtc_helper_funcs flipctl_crtc_helper_funcs = {
+	.mode_valid = flipctl_crtc_mode_valid,
+	.atomic_check = flipctl_crtc_check,
+	.atomic_begin = flipctl_begin_frame,
+	.atomic_flush = flipctl_end_frame,
+};
+
+static const struct drm_crtc_funcs flipctl_crtc_funcs = {
+	.reset = drm_atomic_helper_crtc_reset,
+	.destroy = drm_crtc_cleanup,
+	.set_config = drm_atomic_helper_set_config,
+	.page_flip = drm_atomic_helper_page_flip,
+	.atomic_duplicate_state = drm_atomic_helper_crtc_duplicate_state,
+	.atomic_destroy_state = drm_atomic_helper_crtc_destroy_state,
+};
+
+static const struct drm_encoder_funcs flipctl_encoder_funcs = {
+	.destroy = drm_encoder_cleanup,
+};
+
+static int flipctl_connector_get_modes(struct drm_connector *connector)
+{
+	struct flipctl_device *fctl = drm_to_flipctl_device(connector->dev);
+
+	return drm_connector_helper_get_modes_fixed(connector, fctl->mode);
+}
+
+static const struct drm_connector_helper_funcs flipctl_connector_hfuncs = {
+	.get_modes = flipctl_connector_get_modes,
+};
+
+static const struct drm_connector_funcs flipctl_connector_funcs = {
+	.reset = drm_atomic_helper_connector_reset,
+	.fill_modes = drm_helper_probe_single_connector_modes,
+	.destroy = drm_connector_cleanup,
+	.atomic_duplicate_state = drm_atomic_helper_connector_duplicate_state,
+	.atomic_destroy_state = drm_atomic_helper_connector_destroy_state,
+
+};
+
+static const struct drm_mode_config_funcs flipctl_mode_config_funcs = {
+	.fb_create = drm_gem_fb_create,
+	.atomic_check = drm_atomic_helper_check,
+	.atomic_commit = drm_atomic_helper_commit,
+};
+
+static const struct drm_display_mode flipctl_display_mode = {
+	DRM_SIMPLE_MODE(258, 144, 58, 38),
+};
+
+static const struct spi_device_id flipctl_ids[] = {
+	{"flipctl-display", (kernel_ulong_t)&flipctl_display_mode},
+	{},
+};
+MODULE_DEVICE_TABLE(spi, flipctl_ids);
+
+static const struct of_device_id flipctl_of_match[] = {
+	{.compatible = "flipper,flipctl-display", &flipctl_display_mode},
+	{},
+};
+MODULE_DEVICE_TABLE(of, flipctl_of_match);
+
+static const u32 flipctl_formats[] = {
+	DRM_FORMAT_XRGB8888,
+};
+
+static int flipctl_pipe_init(struct drm_device *dev,
+				  struct flipctl_device *fctl,
+				  const u32 *formats, unsigned int format_count,
+				  const u64 *format_modifiers)
+{
+	int ret;
+	struct drm_encoder *encoder = &fctl->encoder;
+	struct drm_plane *plane = &fctl->plane;
+	struct drm_crtc *crtc = &fctl->crtc;
+	struct drm_connector *connector = &fctl->connector;
+
+	drm_plane_helper_add(plane, &flipctl_plane_helper_funcs);
+	ret = drm_universal_plane_init(dev, plane, 0,
+				       &flipctl_plane_funcs,
+				       formats, format_count,
+				       format_modifiers,
+				       DRM_PLANE_TYPE_PRIMARY, NULL);
+	if (ret)
+		return ret;
+
+	drm_crtc_helper_add(crtc, &flipctl_crtc_helper_funcs);
+	ret = drm_crtc_init_with_planes(dev, crtc, plane, NULL,
+					&flipctl_crtc_funcs, NULL);
+	if (ret)
+		return ret;
+
+	encoder->possible_crtcs = drm_crtc_mask(crtc);
+	ret = drm_encoder_init(dev, encoder, &flipctl_encoder_funcs,
+			       DRM_MODE_ENCODER_NONE, NULL);
+	if (ret)
+		return ret;
+
+	ret = drm_connector_init(&fctl->drm, &fctl->connector,
+				 &flipctl_connector_funcs,
+				 DRM_MODE_CONNECTOR_SPI);
+	if (ret)
+		return ret;
+
+	drm_connector_helper_add(&fctl->connector,
+				 &flipctl_connector_hfuncs);
+
+	return drm_connector_attach_encoder(connector, encoder);
+}
+
+static int flipctl_probe(struct spi_device *spi)
+{
+	int ret;
+	struct device *dev;
+	struct flipctl_device *fctl;
+	struct drm_device *drm;
+
+	dev = &spi->dev;
+	spi->bits_per_word = 16;
+
+	ret = spi_setup(spi);
+	if (ret < 0)
+		return dev_err_probe(dev, ret, "Failed to setup spi device\n");
+
+	if (!dev->coherent_dma_mask) {
+		ret = dma_coerce_mask_and_coherent(dev, DMA_BIT_MASK(32));
+		if (ret)
+			return dev_err_probe(dev, ret, "Failed to set dma mask\n");
+	}
+
+	fctl = devm_drm_dev_alloc(dev, &flipctl_drm_driver,
+				 struct flipctl_device, drm);
+	if (!fctl)
+		return -ENOMEM;
+
+	spi_set_drvdata(spi, fctl);
+
+	fctl->spi = spi;
+	drm = &fctl->drm;
+	ret = drmm_mode_config_init(drm);
+	if (ret)
+		return dev_err_probe(dev, ret, "Failed to initialize drm config\n");
+
+	fctl->active_gpio = devm_gpiod_get_optional(dev, "active", GPIOD_OUT_LOW);
+	if (!fctl->active_gpio)
+		dev_warn(dev, "Active gpio not defined\n");
+
+	drm->mode_config.funcs = &flipctl_mode_config_funcs;
+	fctl->mode = spi_get_device_match_data(spi);
+	fctl->tx_buffer_size = (fctl->mode->hdisplay) * (fctl->mode->vdisplay);
+
+	fctl->tx_buffer = devm_kzalloc(dev, fctl->tx_buffer_size, GFP_KERNEL);
+	if (!fctl->tx_buffer)
+		return -ENOMEM;
+
+	drm->mode_config.min_width = fctl->mode->hdisplay;
+	drm->mode_config.max_width = fctl->mode->hdisplay;
+	drm->mode_config.min_height = fctl->mode->vdisplay;
+	drm->mode_config.max_height = fctl->mode->vdisplay;
+
+	ret = flipctl_pipe_init(drm, fctl, flipctl_formats,
+				     ARRAY_SIZE(flipctl_formats),
+				     NULL);
+	if (ret)
+		return dev_err_probe(dev, ret, "Failed to initialize display pipeline.\n");
+
+	drm_mode_config_reset(drm);
+
+	ret = drm_dev_register(drm, 0);
+	if (ret)
+		return dev_err_probe(dev, ret, "Failed to register drm device.\n");
+
+	drm_client_setup(drm, NULL);
+
+	return 0;
+}
+
+static void flipctl_remove(struct spi_device *spi)
+{
+	struct flipctl_device *fctl = spi_get_drvdata(spi);
+
+	drm_dev_unplug(&fctl->drm);
+	drm_atomic_helper_shutdown(&fctl->drm);
+}
+
+static struct spi_driver flipctl_spi_driver = {
+	.driver = {
+		.name = "flipctl",
+		.of_match_table = flipctl_of_match,
+	},
+	.probe = flipctl_probe,
+	.remove = flipctl_remove,
+	.id_table = flipctl_ids,
+};
+module_spi_driver(flipctl_spi_driver);
+
+MODULE_AUTHOR("Alexey Charkov <alchark@gmail.com>");
+MODULE_DESCRIPTION("SPI Protocol driver for the flipctl display");
+MODULE_LICENSE("GPL");

