---
 arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts | 28 +++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts b/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts
index cce34c541f7c..405005f92666 100644
--- a/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts
@@ -834,6 +834,20 @@ hp_det_l: hp-det-l {
 		};
 	};
 
+	spi3 {
+		spi3m2_wo_miso: spi3m2-pins {
+			rockchip,pins =
+				/* spi3_clk_m2 */
+				<4 RK_PA7 9 &pcfg_pull_none>,
+				/* spi3_mosi_m2 */
+				<4 RK_PA4 9 &pcfg_pull_none>;
+		};
+
+		flipctl_gpio: spi3m2-miso {
+			rockchip,pins = <4 RK_PA6 RK_FUNC_GPIO &pcfg_pull_none>;
+		};
+	};
+
 	usb {
 		usb3_host_pwren_h: usb3-host-pwren-h {
 			rockchip,pins = <0 RK_PC7 RK_FUNC_GPIO &pcfg_pull_none>;
@@ -884,6 +898,20 @@ flash@0 {
 	};
 };
 
+&spi3 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&spi3m2_csn0 &spi3m2_wo_miso &flipctl_gpio>;
+	status = "okay";
+
+	display@0 {
+		compatible = "flipper,flipctl-display";
+		reg = <0>;
+		active-gpios = <&gpio4 RK_PA6 GPIO_ACTIVE_LOW>;
+		spi-max-frequency = <25000000>;
+		spi-rx-bus-width = <0>;
+	};
+};
+
 &u2phy0 {
 	status = "okay";
 };

