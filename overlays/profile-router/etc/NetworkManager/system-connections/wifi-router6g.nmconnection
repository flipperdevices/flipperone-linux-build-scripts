# 6 GHz is inert on mt7921u (not 6E silicon). NM won't load this as-is —
# band=a channel=5 is invalid — kept for a future 6E dongle; router-* ignore it.
[connection]
id=Router Wi-Fi 6 GHz
type=wifi
autoconnect=false
master=br-lan
slave-type=bridge

[wifi]
band=a
channel=5
channel-width=80
mode=ap
ssid=FlipperOne_6GHz_WIFISSIDSERIAL

[wifi-security]
key-mgmt=wpa-psk
proto=rsn
pairwise=ccmp
psk=flipperone
