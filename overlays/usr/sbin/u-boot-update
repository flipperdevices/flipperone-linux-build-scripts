#!/bin/bash
set -e

BOOT_DIR="/boot"
EXTLINUX_DIR="${BOOT_DIR}/extlinux"
EXTLINUX_CONF="${EXTLINUX_DIR}/extlinux.conf"
UBOOT_MENU_DIR="/usr/share/u-boot-menu"
ENABLED_DIR="${UBOOT_MENU_DIR}/enabled.d"
FEATURES_DIR="${UBOOT_MENU_DIR}/features.d"
FUNCTIONS_LIB="${UBOOT_MENU_DIR}/functions.sh"

# Load common functions
if [ -f "${FUNCTIONS_LIB}" ]; then
    . "${FUNCTIONS_LIB}"
fi

# Get list of kernels, sorted by version (newest first)
_VERSIONS=$(linux-version list | linux-version sort --reverse | uniq)

if [ -z "${_VERSIONS}" ]; then
    echo "P: No kernels found"
    exit 0
fi

# Redirect stdout to stderr due to Debconf usage
exec 1>&2

unset U_BOOT_PROFILE_TEMPLATE
if [ -e /etc/default/u-boot ]; then
    . /etc/default/u-boot
fi

U_BOOT_UPDATE="${U_BOOT_UPDATE:-true}"
if [ "${U_BOOT_UPDATE}" != "true" ]; then
    echo "P: u-boot-update is disabled in /etc/default/u-boot"
    exit 0
fi

# Checking exlinux directory
echo -n "P: Checking for EXTLINUX directory..."
if [ ! -e "${EXTLINUX_DIR}" ]; then
    echo " not found"
    echo -n "P: Creating EXTLINUX directory..."
    mkdir -p "${EXTLINUX_DIR}"
    echo " done: ${EXTLINUX_DIR}"
else
    echo " found."
fi

# Get root UUID for default bootargs
if [ -z "${U_BOOT_ROOT}" ]; then
    U_BOOT_ROOT="root=UUID=$(findmnt / -n -o UUID || :)"
fi
DEFAULT_BOOTARGS="${U_BOOT_ROOT} ${U_BOOT_PARAMETERS}"

# Setting defaults if /etc/default/u-boot is missing

U_BOOT_ALTERNATIVES="${U_BOOT_ALTERNATIVES:-default rescue}"
U_BOOT_DEFAULT="${U_BOOT_DEFAULT:-l0}"
U_BOOT_TIMEOUT="${U_BOOT_TIMEOUT:-50}"
U_BOOT_MENU_TITLE="${U_BOOT_MENU_TITLE:-U-Boot menu}"
U_BOOT_MENU_LABEL="${U_BOOT_MENU_LABEL:-Debian GNU/Linux}"
U_BOOT_FDT_DIR="${U_BOOT_FDT_DIR:-/usr/lib/linux-image-}"

umask 0066
_EXTLINUX_CONF_TEMP="$(mktemp "${TMPDIR:-/tmp}/u-boot-update.XXXXXX")"
trap 'trap - EXIT INT TERM; rm -f "${_EXTLINUX_CONF_TEMP}"' EXIT INT TERM

# Start generating extlinux.conf content
cat > "${_EXTLINUX_CONF_TEMP}" <<EOF
## ${EXTLINUX_CONF}
## Generated by u-boot-update

default ${U_BOOT_DEFAULT}
menu title ${U_BOOT_MENU_TITLE}
prompt 1
timeout ${U_BOOT_TIMEOUT}

EOF

_VERBOSE=
_NUMBER=0
_discovered_boards=""
# Initialize global fingerprint tracking for deduplication
_seen_fingerprints=" "

processed_legend=""
uboot_menu_title="${U_BOOT_MENU_TITLE}"

for _KERNEL_VERSION in ${_VERSIONS}; do
    echo "P: Writing config for ${BOOT_DIR}/vmlinuz-${_KERNEL_VERSION}..."

    initrd_path="${BOOT_DIR}/initrd.img-${_KERNEL_VERSION}"
    if [ ! -f "${initrd_path}" ]; then
        # Try initramfs name
        initrd_path="${BOOT_DIR}/initramfs-${_KERNEL_VERSION}.img"
    fi

    # Base variables for this kernel (used to initialize per-board vars)
    base_kernel="${BOOT_DIR}/vmlinuz-${_KERNEL_VERSION}"
    base_initrd=""
    if [ -f "${initrd_path}" ]; then
        base_initrd="${BOOT_DIR}/$(basename "${initrd_path}")"
    fi

    if [ -d "${U_BOOT_FDT_DIR}${_KERNEL_VERSION}" ]; then
        base_fdtdir="${U_BOOT_FDT_DIR}${_KERNEL_VERSION}/"
    else
        base_fdtdir=""
    fi

    base_profile_name="${U_BOOT_MENU_LABEL} ${_KERNEL_VERSION}"

    # Iterate over enabled feature sets
    ENABLED_FILES=$(ls -1 "${ENABLED_DIR}"/* 2>/dev/null | sort)
    if [ -z "$ENABLED_FILES" ]; then
        # Fallback if no enabled features found
        ENABLED_FILES="${U_BOOT_ALTERNATIVES}"
    fi

    for enabled_file in $ENABLED_FILES; do
        # Cleanup previous iteration's board data
        cleanup_boards

        # Initialize default (non-board-specific) entry
        init_default_entry

        skip_feature=""
        any_feature=""
        skip_entry=""
        global_skip_entry=""

        if [ -f "$enabled_file" ]; then
            # Apply features defined in the enabled file
            while IFS= read -r feature || [ -n "$feature" ]; do
                # Skip comments and empty lines
                feature="${feature%%#*}"
                [ -n "$feature" ] || continue

                feature_script="${FEATURES_DIR}/${feature}"
                if [ -f "${feature_script}" ]; then
                    [ -z "${_VERBOSE}" ] || echo "P:   Feature: ${feature}"
                    skip_feature=""

                    # Source the feature script
                    . "${feature_script}"

                    if [ -n "$skip_feature" ]; then
                        [ -z "${_VERBOSE}" ] || echo "P:     (skipped)"
                        continue
                    fi

                    any_feature=1

                    # Check if feature set global skip_entry
                    if [ -n "$skip_entry" ]; then
                        global_skip_entry=1
                        break
                    fi
                else
                    [ -z "${_VERBOSE}" ] || echo "P:   Feature: ${feature} (not found, skipping)"
                fi
            done < "${enabled_file}"
        fi

        if [ -n "$global_skip_entry" ]; then
            [ -z "${_VERBOSE}" ] || echo "P: Skipping all entries for ${enabled_file##*/} (skip_entry set)"
            continue
        fi

        if [ -z "$any_feature" ]; then
            [ -z "${_VERBOSE}" ] || echo "P: No features processed for ${enabled_file##*/}, skipping"
            continue
        fi

        # Inject all entries (with deduplication)
        if ! inject_all_entries; then
            echo "P: No entries generated for ${enabled_file##*/}"
        fi
    done
done

fixup_menu_title
update_config "${EXTLINUX_CONF}" "${_EXTLINUX_CONF_TEMP}"
