#!/bin/sh

process_feature() {
    add_legend "USB-C Router" "USB Ethernet + DHCP + iperf3 + NAT to Ethernet"

    if ! has_config USB_CONFIGFS_NCM || ! has_config USB_F_NCM; then
        skip_entry=1
        return
    fi

    # Always add bootargs and name suffix to default entry
    add_bootargs "systemd.unit=usbc-router.target"
    append_name "[USB-C Router]"

    # Also add board-specific entries if usb-ncm.dtbo exists for that board
    # -z: skip boards where dtbo is missing (don't create entry for them)
    # No -e: don't touch default entry again (we already handled it above)
    add_board_dtbo -z -n "USB-C Router" -d "usb-ncm" \
        -A "systemd.unit=usbc-router.target"
}

process_feature
unset -f process_feature
